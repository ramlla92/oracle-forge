# Oracle Forge — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.

# ── LLM ─────────────────────────────────────────────────────────────────────
# OpenRouter API key (openrouter.ai/settings/keys). Default model: google/gemini-2.0-flash-001
OPEN_ROUTER_KEY=sk-or-v1-...

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=yelp
POSTGRES_USER=oracle_forge
POSTGRES_PASSWORD=your_password_here

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=

# ── File-based databases ─────────────────────────────────────────────────────
SQLITE_PATH=db/dab_sqlite.db
DUCKDB_PATH=db/yelp_user.db
