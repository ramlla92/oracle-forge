# Oracle Forge — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.

# ── LLM ─────────────────────────────────────────────────────────────────────
OPEN_ROUTER_KEY=sk-or-v1-...

# ── PostgreSQL (primary — Yelp) ───────────────────────────────────────────────
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=yelp
POSTGRES_USER=oracle_forge
POSTGRES_PASSWORD=your_password_here

# ── PostgreSQL (additional datasets) ─────────────────────────────────────────
BOOKREVIEW_POSTGRES_DB=bookreview_db
CRM_SUPPORT_POSTGRES_DB=crm_support
PANCANCER_POSTGRES_DB=pancancer_clinical

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=

# ── File-based databases ─────────────────────────────────────────────────────
SQLITE_PATH=db/dab_sqlite.db
DUCKDB_PATH=db/yelp_user.db

# ── File-based datasets (SQLite + DuckDB) ────────────────────────────────────
DEPS_DEV_SQLITE_PATH=DataAgentBench/query_DEPS_DEV_V1/query_dataset/package_query.db
DEPS_DEV_DUCKDB_PATH=DataAgentBench/query_DEPS_DEV_V1/query_dataset/project_query.db

# ── DataAgentBench root ───────────────────────────────────────────────────────
DAB_ROOT=/path/to/oracle-forge/DataAgentBench
